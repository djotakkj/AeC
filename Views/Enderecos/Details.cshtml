@model AeC.Enderecos.Models.Endereco

@{
    ViewData["Title"] = "Detalhes do Endereço";
}

<div class="card details-card">

    <div class="card-header-custom">
        <div>
            <h1 class="card-title">Detalhes do Endereço</h1>
            <p class="card-subtitle">Informações completas do endereço.</p>
        </div>
    </div>

    <div class="card-body-custom">

        <div class="detail-row">
            <span class="detail-label">CEP</span>
            <span class="detail-value">@Model.Cep</span>
        </div>
        <div class="detail-row">
            <span class="detail-label">Logradouro</span>
            <span class="detail-value">@Model.Logradouro</span>
        </div>
        <div class="detail-row">
            <span class="detail-label">Número</span>
            <span class="detail-value">@Model.Numero</span>
        </div>
        <div class="detail-row">
            <span class="detail-label">Complemento</span>
            <span class="detail-value">@(string.IsNullOrWhiteSpace(Model.Complemento) ? "—" : Model.Complemento)</span>
        </div>
        <div class="detail-row">
            <span class="detail-label">Bairro</span>
            <span class="detail-value">@Model.Bairro</span>
        </div>
        <div class="detail-row">
            <span class="detail-label">Cidade</span>
            <span class="detail-value">@Model.Cidade</span>
        </div>
        <div class="detail-row">
            <span class="detail-label">Estado (UF)</span>
            <span class="detail-value"><span class="badge-uf">@Model.Uf</span></span>
        </div>

        <div class="form-actions" style="margin-top:20px;">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">Editar</a>
            <a asp-action="Index" class="btn btn-secondary">Voltar à lista</a>
        </div>

    </div>
</div>
