@model AeC.Enderecos.Models.Endereco

@{
    ViewData["Title"] = "Editar Endereço";
}

<div class="card">

    <div class="card-header-custom">
        <div>
            <h1 class="card-title">Editar Endereço</h1>
            <p class="card-subtitle">Atualize os dados do endereço abaixo.</p>
        </div>
    </div>

    <div class="card-body-custom">
        <div class="form-section">

            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                @* Campo oculto com o ID — necessário para o POST saber qual registro atualizar *@
                <input type="hidden" asp-for="Id" />

                <div class="form-row-cep form-group">
                    <div>
                        <label asp-for="Cep" class="form-label">CEP</label>
                        <input asp-for="Cep" class="form-control" placeholder="00000-000" maxlength="9" />
                        <span asp-validation-for="Cep" class="text-danger"></span>
                    </div>
                    <div>
                        <label asp-for="Numero" class="form-label">Número</label>
                        <input asp-for="Numero" class="form-control" />
                        <span asp-validation-for="Numero" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-divider"></div>

                <div class="form-group">
                    <label asp-for="Logradouro" class="form-label">Logradouro</label>
                    <input asp-for="Logradouro" class="form-control" />
                    <span asp-validation-for="Logradouro" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Complemento" class="form-label">
                        Complemento
                        <span class="label-opcional">(opcional)</span>
                    </label>
                    <input asp-for="Complemento" class="form-control" />
                    <span asp-validation-for="Complemento" class="text-danger"></span>
                </div>

                <div class="form-row form-group">
                    <div>
                        <label asp-for="Bairro" class="form-label">Bairro</label>
                        <input asp-for="Bairro" class="form-control" />
                        <span asp-validation-for="Bairro" class="text-danger"></span>
                    </div>
                    <div>
                        <label asp-for="Cidade" class="form-label">Cidade</label>
                        <input asp-for="Cidade" class="form-control" />
                        <span asp-validation-for="Cidade" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-group" style="max-width:100px">
                    <label asp-for="Uf" class="form-label">UF</label>
                    <input asp-for="Uf" class="form-control" maxlength="2" style="text-transform:uppercase" />
                    <span asp-validation-for="Uf" class="text-danger"></span>
                </div>

                <div class="form-divider"></div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Salvar Alterações</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
